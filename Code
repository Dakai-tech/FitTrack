                <!-- Calorie Distribution -->
                <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-5">
                    <h3 class="font-bold text-slate-900 mb-4">热量分布</h3>
                    <div class="relative h-48">
                        <canvas id="macroChart"></canvas>
                    </div>
