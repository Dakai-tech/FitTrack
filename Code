                <!-- Today's Log -->
                <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
                    <div class="p-5 border-b border-slate-100">
                        <h3 class="font-bold text-slate-900 flex items-center justify-between">
                            <span><i class="fas fa-list-ul text-indigo-600 mr-2"></i>今日记录</span>
                            <span id="logCount" class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded-full">0 项</span>
