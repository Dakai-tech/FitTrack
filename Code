            <!-- Right Column: Charts & Insights -->
            <div class="lg:col-span-5 space-y-6">
                
                <!-- Weight Chart -->
                <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-5">
                    <div class="flex items-center justify-between mb-4">
                        <h3 class="font-bold text-slate-900">体重趋势</h3>
                        <select id="chartRange" onchange="updateChartRange()" class="text-xs bg-slate-100 border-none rounded-lg px-2 py-1 text-slate-600 outline-none cursor-pointer">
