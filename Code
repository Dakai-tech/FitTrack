<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>智能健身追踪 Agent - WOD + 饮食 + 体重</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/tesseract.js@4/dist/tesseract.min.js"></script>
    <style>
        body { font-family: 'Noto Sans SC', 'Inter', sans-serif; }
        .glass-panel {
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }
        .gradient-text {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .card-3d {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .card-3d:hover {
            transform: translateY(-2px);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
        }
        .scan-line {
            position: absolute;
            width: 100%;
            height: 2px;
            background: linear-gradient(90deg, transparent, #10b981, transparent);
            animation: scan 2s linear infinite;
            top: 0;
        }
        @keyframes scan {
            0% { top: 0; opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { top: 100%; opacity: 0; }
        }
        .pulse-ring {
            animation: pulse-ring 2s cubic-bezier(0.215, 0.61, 0.355, 1) infinite;
        }
        @keyframes pulse-ring {
            0% { transform: scale(0.8); opacity: 0.8; }
            100% { transform: scale(1.4); opacity: 0; }
        }
        .food-item-enter {
            animation: slideInRight 0.3s ease-out;
        }
        @keyframes slideInRight {
            from { opacity: 0; transform: translateX(-20px); }
            to { opacity: 1; transform: translateX(0); }
        }
        .ocr-highlight {
            background: linear-gradient(120deg, #fef3c7 0%, #fef3c7 100%);
            background-repeat: no-repeat;
            background-size: 100% 40%;
            background-position: 0 88%;
        }
        /* Custom scrollbar */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
        
        .meal-badge-breakfast { @apply bg-amber-100 text-amber-800 border-amber-200; }
        .meal-badge-lunch { @apply bg-orange-100 text-orange-800 border-orange-200; }
        .meal-badge-dinner { @apply bg-indigo-100 text-indigo-800 border-indigo-200; }
        .meal-badge-snack { @apply bg-pink-100 text-pink-800 border-pink-200; }
        .meal-badge-exercise { @apply bg-emerald-100 text-emerald-800 border-emerald-200; }
    </style>
</head>
<body class="bg-slate-50 min-h-screen text-slate-800">

    <!-- Header -->
    <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-xl border-b border-slate-200/60">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="relative">
                        <div class="w-10 h-10 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-xl flex items-center justify-center shadow-lg shadow-indigo-500/30">
                            <i class="fas fa-bolt text-white text-lg"></i>
                        </div>
                        <div class="absolute -top-1 -right-1 w-3 h-3 bg-emerald-400 rounded-full border-2 border-white"></div>
                    </div>
                    <div>
                        <h1 class="text-xl font-bold bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent">FitTrack Agent</h1>
                        <p class="text-xs text-slate-500 font-medium" id="headerDate">--</p>
                    </div>
                </div>
                <div class="flex items-center space-x-3">
                    <button onclick="showProfile()" class="p-2 hover:bg-slate-100 rounded-lg transition-colors text-slate-600">
                        <i class="fas fa-user-cog"></i>
                    </button>
                    <button onclick="exportData()" class="hidden sm:flex items-center px-3 py-2 bg-slate-100 hover:bg-slate-200 rounded-lg text-sm font-medium text-slate-700 transition-colors">
                        <i class="fas fa-download mr-2"></i>导出
                    </button>
                </div>
            </div>
        </div>
    </header>

    <!-- Profile Modal -->
    <div id="profileModal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 hidden items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl max-w-lg w-full p-6 transform transition-all scale-100">
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-xl font-bold text-slate-900">个人档案</h2>
                <button onclick="closeProfile()" class="text-slate-400 hover:text-slate-600"><i class="fas fa-times text-xl"></i></button>
            </div>
            <form id="profileForm" class="space-y-4">
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">昵称</label>
                        <input type="text" id="pName" required class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none transition-all" placeholder="你的名字">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">性别</label>
                        <select id="pGender" class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none">
                            <option value="male">男</option>
                            <option value="female">女</option>
                        </select>
                    </div>
                </div>
                <div class="grid grid-cols-3 gap-3">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">身高 (cm)</label>
                        <input type="number" id="pHeight" required class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none" placeholder="175">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">当前体重</label>
                        <input type="number" id="pWeight" step="0.1" required class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none" placeholder="70.0">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">目标体重</label>
                        <input type="number" id="pTarget" step="0.1" required class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none" placeholder="65.0">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">年龄</label>
                    <input type="number" id="pAge" required class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none" placeholder="28">
                </div>
                <div class="bg-indigo-50 rounded-lg p-3 text-sm text-indigo-800">
                    <i class="fas fa-info-circle mr-1"></i>
                    系统将根据你的数据自动计算每日热量预算和基础代谢率
                </div>
                <button type="submit" class="w-full bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white font-bold py-3 rounded-xl shadow-lg shadow-indigo-500/30 transition-all transform hover:scale-[1.02]">
                    保存档案
                </button>
            </form>
        </div>
    </div>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 space-y-6">

        <!-- Top Stats Dashboard -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
            <!-- Weight Card -->
            <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 card-3d relative overflow-hidden">
                <div class="absolute top-0 right-0 w-20 h-20 bg-gradient-to-br from-blue-100 to-transparent rounded-bl-full opacity-50"></div>
                <div class="flex items-center justify-between mb-3">
                    <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">空腹体重</span>
                    <div class="bg-blue-50 p-1.5 rounded-lg"><i class="fas fa-weight-scale text-blue-600 text-sm"></i></div>
                </div>
                <div class="flex items-baseline space-x-1">
                    <span id="dispWeight" class="text-2xl font-bold text-slate-900">--</span>
                    <span class="text-sm text-slate-500">kg</span>
                </div>
                <div class="mt-2 flex items-center text-xs">
                    <span id="weightChange" class="font-medium">--</span>
                    <span class="text-slate-400 ml-1">vs 昨日</span>
                </div>
                <button onclick="toggleWeightInput()" class="mt-3 w-full py-1.5 text-xs font-medium text-blue-600 bg-blue-50 hover:bg-blue-100 rounded-lg transition-colors">
                    <i class="fas fa-plus mr-1"></i>记录今日体重
                </button>
            </div>

            <!-- BMI Card -->
            <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 card-3d relative overflow-hidden">
                <div class="absolute top-0 right-0 w-20 h-20 bg-gradient-to-br from-purple-100 to-transparent rounded-bl-full opacity-50"></div>
                <div class="flex items-center justify-between mb-3">
                    <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">BMI</span>
                    <div class="bg-purple-50 p-1.5 rounded-lg"><i class="fas fa-chart-pie text-purple-600 text-sm"></i></div>
                </div>
                <div class="flex items-baseline space-x-2">
                    <span id="dispBMI" class="text-2xl font-bold text-slate-900">--</span>
                    <span id="dispBMITag" class="text-xs px-2 py-0.5 rounded-full bg-slate-100 text-slate-600 font-medium">--</span>
                </div>
                <div class="mt-3 w-full bg-slate-100 rounded-full h-1.5">
                    <div id="bmiBar" class="h-1.5 rounded-full bg-gradient-to-r from-blue-400 to-purple-500 transition-all duration-700" style="width: 0%"></div>
                </div>
            </div>

            <!-- Calories In -->
            <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 card-3d relative overflow-hidden">
                <div class="absolute top-0 right-0 w-20 h-20 bg-gradient-to-br from-orange-100 to-transparent rounded-bl-full opacity-50"></div>
                <div class="flex items-center justify-between mb-3">
                    <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">摄入</span>
                    <div class="bg-orange-50 p-1.5 rounded-lg"><i class="fas fa-utensils text-orange-600 text-sm"></i></div>
                </div>
                <div class="flex items-baseline space-x-1">
                    <span id="dispCalsIn" class="text-2xl font-bold text-slate-900">0</span>
                    <span class="text-sm text-slate-500">kcal</span>
                </div>
                <div class="mt-3 w-full bg-slate-100 rounded-full h-1.5">
                    <div id="calInBar" class="h-1.5 rounded-full bg-orange-500 transition-all duration-700" style="width: 0%"></div>
                </div>
            </div>

            <!-- Calories Out / WOD -->
            <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 card-3d relative overflow-hidden">
                <div class="absolute top-0 right-0 w-20 h-20 bg-gradient-to-br from-emerald-100 to-transparent rounded-bl-full opacity-50"></div>
                <div class="flex items-center justify-between mb-3">
                    <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">消耗 (WOD)</span>
                    <div class="bg-emerald-50 p-1.5 rounded-lg"><i class="fas fa-fire text-emerald-600 text-sm"></i></div>
                </div>
                <div class="flex items-baseline space-x-1">
                    <span id="dispCalsOut" class="text-2xl font-bold text-slate-900">0</span>
                    <span class="text-sm text-slate-500">kcal</span>
                </div>
                <div class="mt-2 flex items-center text-xs text-emerald-600 font-medium">
                    <i class="fas fa-dumbbell mr-1"></i>
                    <span id="wodCount">0 个 WOD</span>
                </div>
            </div>
        </div>

        <!-- Net Calories & Target -->
        <div class="bg-gradient-to-r from-slate-900 to-slate-800 rounded-2xl p-6 text-white shadow-xl">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                <div>
                    <h3 class="text-lg font-bold mb-1">今日热量净余额</h3>
                    <p class="text-slate-400 text-sm">基础代谢 <span id="netBMR" class="text-white font-semibold">--</span> + 运动消耗 - 饮食摄入</p>
                </div>
                <div class="flex items-center space-x-6">
                    <div class="text-center">
                        <div class="text-3xl font-bold" id="netCalories">--</div>
                        <div class="text-xs text-slate-400 mt-1">kcal 剩余</div>
                    </div>
                    <div class="h-12 w-px bg-slate-700"></div>
                    <div class="text-center">
                        <div class="text-3xl font-bold text-emerald-400" id="targetProgress">--%</div>
                        <div class="text-xs text-slate-400 mt-1">目标进度</div>
                    </div>
                </div>
            </div>
            <div class="mt-4 w-full bg-slate-700/50 rounded-full h-2">
                <div id="netProgressBar" class="h-2 rounded-full bg-gradient-to-r from-emerald-400 to-cyan-400 transition-all duration-700" style="width: 0%"></div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
            
            <!-- Left Column: Inputs -->
            <div class="lg:col-span-7 space-y-6">
                
                <!-- WOD Photo Upload -->
                <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
                    <div class="p-5 border-b border-slate-100 flex items-center justify-between">
                        <h3 class="font-bold text-slate-900 flex items-center">
                            <i class="fas fa-camera text-emerald-600 mr-2"></i>
                            WOD 记录
                        </h3>
                        <span class="text-xs text-slate-500 bg-slate-100 px-2 py-1 rounded-full">支持拍照或截图上传</span>
                    </div>
                    
                    <div class="p-5">
                        <!-- Upload Zone -->
                        <div id="wodUploadZone" class="border-2 border-dashed border-slate-300 rounded-xl p-8 text-center hover:border-emerald-400 hover:bg-emerald-50/30 transition-all cursor-pointer relative overflow-hidden" onclick="document.getElementById('wodInput').click()">
                            <input type="file" id="wodInput" accept="image/*" class="hidden" onchange="handleWODUpload(event)">
                            <div id="wodPlaceholder">
                                <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-3">
                                    <i class="fas fa-cloud-upload-alt text-2xl text-slate-400"></i>
                                </div>
                                <p class="text-sm font-medium text-slate-700">点击上传 WOD 照片</p>
                                <p class="text-xs text-slate-500 mt-1">系统将自动识别训练内容</p>
                            </div>
                            <div id="wodPreview" class="hidden relative">
                                <img id="wodPreviewImg" class="max-h-48 mx-auto rounded-lg shadow-md" src="" alt="WOD">
                                <div id="wodScanning" class="absolute inset-0 bg-black/50 rounded-lg hidden flex items-center justify-center">
                                    <div class="scan-line"></div>
                                    <div class="text-white text-sm font-medium"><i class="fas fa-spinner fa-spin mr-2"></i>OCR 识别中...</div>
                                </div>
                            </div>
                        </div>

                        <!-- OCR Result -->
                        <div id="ocrResult" class="hidden mt-4 bg-slate-50 rounded-lg p-4 border border-slate-200">
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-xs font-semibold text-slate-500 uppercase">识别结果</span>
                                <button onclick="clearWOD()" class="text-xs text-red-500 hover:text-red-700"><i class="fas fa-trash mr-1"></i>清除</button>
                            </div>
                            <div id="ocrText" class="text-sm text-slate-700 font-mono whitespace-pre-wrap max-h-32 overflow-y-auto"></div>
                            <div class="mt-3 flex items-center justify-between">
                                <div class="flex items-center space-x-2">
                                    <span class="text-xs text-slate-500">估算消耗:</span>
                                    <span id="wodCalEstimate" class="text-lg font-bold text-emerald-600">--</span>
                                    <span class="text-xs text-slate-500">kcal</span>
                                </div>
                                <button onclick="confirmWOD()" class="px-4 py-1.5 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium rounded-lg transition-colors">
                                    <i class="fas fa-check mr-1"></i>确认添加
                                </button>
                            </div>
                        </div>

                        <!-- Manual WOD Entry -->
                        <div class="mt-4 pt-4 border-t border-slate-100">
                            <p class="text-xs text-slate-500 mb-3 font-medium">或手动记录训练</p>
                            <div class="grid grid-cols-2 gap-3">
                                <input type="text" id="wodName" placeholder="训练名称 (如: Fran)" class="px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-emerald-500 outline-none">
                                <input type="number" id="wodCals" placeholder="估算消耗 (kcal)" class="px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-emerald-500 outline-none">
                            </div>
                            <button onclick="addManualWOD()" class="mt-2 w-full py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 text-sm font-medium rounded-lg transition-colors">
                                <i class="fas fa-plus mr-1"></i>添加手动记录
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Food Entry -->
                <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
                    <div class="p-5 border-b border-slate-100 flex items-center justify-between">
                        <h3 class="font-bold text-slate-900 flex items-center">
                            <i class="fas fa-utensils text-orange-500 mr-2"></i>
                            饮食记录
                        </h3>
                        <div class="flex space-x-1">
                            <button onclick="setMealType('breakfast')" id="btnBreakfast" class="meal-tab px-3 py-1 text-xs font-medium rounded-full bg-amber-100 text-amber-800 transition-all">早餐</button>
                            <button onclick="setMealType('lunch')" id="btnLunch" class="meal-tab px-3 py-1 text-xs font-medium rounded-full bg-slate-100 text-slate-600 hover:bg-slate-200 transition-all">午餐</button>
                            <button onclick="setMealType('dinner')" id="btnDinner" class="meal-tab px-3 py-1 text-xs font-medium rounded-full bg-slate-100 text-slate-600 hover:bg-slate-200 transition-all">晚餐</button>
                            <button onclick="setMealType('snack')" id="btnSnack" class="meal-tab px-3 py-1 text-xs font-medium rounded-full bg-slate-100 text-slate-600 hover:bg-slate-200 transition-all">加餐</button>
                        </div>
                    </div>
                    
                    <div class="p-5">
                        <div class="relative mb-4">
                            <input type="text" id="foodSearch" placeholder="输入食物名称，自动估算热量..." 
                                class="w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-transparent outline-none transition-all"
                                oninput="searchFood(this.value)" autocomplete="off">
                            <i class="fas fa-search absolute left-3.5 top-3.5 text-slate-400"></i>
                            <div id="foodSuggestions" class="absolute z-10 w-full mt-1 bg-white border border-slate-200 rounded-xl shadow-lg max-h-48 overflow-y-auto hidden"></div>
                        </div>

                        <div class="grid grid-cols-2 gap-3 mb-4">
                            <input type="text" id="foodName" placeholder="食物名称" class="px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-orange-500 outline-none">
                            <div class="flex items-center space-x-2">
                                <input type="number" id="foodAmount" placeholder="份量" value="1" class="w-20 px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-orange-500 outline-none">
                                <select id="foodUnit" class="flex-1 px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-orange-500 outline-none">
                                    <option value="serving">份</option>
                                    <option value="g">克</option>
                                    <option value="bowl">碗</option>
                                    <option value="piece">个</option>
                                </select>
                            </div>
                        </div>
                        
                        <div class="flex items-center justify-between mb-4 p-3 bg-orange-50 rounded-lg">
                            <span class="text-sm text-slate-600">估算热量</span>
                            <span class="text-xl font-bold text-orange-600"><span id="foodCalDisplay">0</span> <span class="text-sm font-normal text-slate-500">kcal</span></span>
                        </div>

                        <input type="hidden" id="currentMealType" value="breakfast">

                        <div class="flex space-x-2 mb-4 overflow-x-auto pb-1">
                            <button onclick="quickFood('燕麦粥', 150)" class="flex-shrink-0 px-3 py-1.5 bg-slate-100 hover:bg-slate-200 rounded-lg text-xs font-medium text-slate-700 transition-colors">燕麦粥</button>
                            <button onclick="quickFood('煮鸡蛋', 70)" class="flex-shrink-0 px-3 py-1.5 bg-slate-100 hover:bg-slate-200 rounded-lg text-xs font-medium text-slate-700 transition-colors">煮鸡蛋</button>
                            <button onclick="quickFood('鸡胸肉(100g)', 165)" class="flex-shrink-0 px-3 py-1.5 bg-slate-100 hover:bg-slate-200 rounded-lg text-xs font-medium text-slate-700 transition-colors">鸡胸肉</button>
                            <button onclick="quickFood('米饭(碗)', 200)" class="flex-shrink-0 px-3 py-1.5 bg-slate-100 hover:bg-slate-200 rounded-lg text-xs font-medium text-slate-700 transition-colors">米饭</button>
                            <button onclick="quickFood('西兰花', 35)" class="flex-shrink-0 px-3 py-1.5 bg-slate-100 hover:bg-slate-200 rounded-lg text-xs font-medium text-slate-700 transition-colors">西兰花</button>
                            <button onclick="quickFood('香蕉', 105)" class="flex-shrink-0 px-3 py-1.5 bg-slate-100 hover:bg-slate-200 rounded-lg text-xs font-medium text-slate-700 transition-colors">香蕉</button>
                        </div>

                        <button onclick="addFood()" class="w-full py-3 bg-gradient-to-r from-orange-500 to-amber-500 hover:from-orange-600 hover:to-amber-600 text-white font-bold rounded-xl shadow-lg shadow-orange-500/30 transition-all transform hover:scale-[1.02]">
